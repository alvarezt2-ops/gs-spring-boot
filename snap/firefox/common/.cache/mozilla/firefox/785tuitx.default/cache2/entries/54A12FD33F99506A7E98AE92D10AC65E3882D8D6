                        "FIXING_ISSUE": {
                            "HEADING": {
                                "V1": "Fixing the issue"
                            },
                            "STEP_1": {
                                "V1": "Create a new document with the same name"
                            },
                            "STEP_2": {
                                "V2": "Copy over the contents of this document to the new document"
                            },
                            "STEP_3": {
                                "V1": "Save and submit the new document"
