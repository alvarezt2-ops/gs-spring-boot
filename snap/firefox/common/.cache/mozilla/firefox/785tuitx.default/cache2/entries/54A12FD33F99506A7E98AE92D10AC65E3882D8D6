            "DOCX": {
                "ISSUE": {
                    "OutdatedFormatIssue": {
                        "FIX_ISSUE": {
                            "STEP_1": {
                                "V1": "Open your DOC file in Microsoft Word."
                            },
                            "STEP_2": {
                                "V1": "Open the File menu."
