                    "MalformedDocumentIssue": {
                        "SUB_HEADING_1": {
                            "V1": "A malformed document is a document which is corrupted or incorrectly encoded."
                        },
                        "SUB_HEADING_2": {
                            "V2": "Although malformed documents can be viewed normally, they may contain hidden viruses that can run malware on the user's machine if opened."
                        }
                    },
                    "MissingAltTextIssue": {
                        "SUB_HEADING_1": {
                            "V1": "The visual content is missing an alternative text tag."
                        },
                        "SUB_HEADING_2": {
                            "V1": "Alternative text provides access to visual content for individuals who are visually impaired. Alternative descriptions ensure that all users can comprehend and engage with the content."
                        }
                    },
                    "MissingTableHeaderIssue": {
                        "SUB_HEADING_1": {
                            "V1": "The table does not have any header cells specified. Headers identify the content of the row/column."
                        },
                        "SUB_HEADING_2": {
                            "V1": "A table header helps screen readers and assistive technologies accurately convey the table's structure and content to users. They also ensure that conversions to accessible formats are accurate."
                        }
                    },
                    "MissingTextAtCellA1Issue": {
                        "SUB_HEADING_1": {
                            "V1": "The spreadsheet does not have any text in cell A1."
                        },
                        "SUB_HEADING_2": {
                            "V1": "Cell A1 should have instructions to provide context for the spreadsheet. It also helps users with screen readers understand the content of the spreadsheet."
                        }
                    },
                    "MissingTitleIssue": {
                        "SUB_HEADING_1": {
                            "V1": "The document does not include a descriptive title in its metadata, which can make it harder for users, especially those using screen readers, to identify the fileâ€™s purpose."
                        },
                        "SUB_HEADING_2": {
                            "V1": "Having a descriptive title allows users to easily identify the document and provides context for the reader. People with cognitive disabilities, limited short-term memory, and reading disabilities also benefit from the ability to identify content by its title."
