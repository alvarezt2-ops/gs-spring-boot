  function semsesterCheck(){
    let course_name = ENV.current_context.name;
    let pos = course_name.search(/(FA|WI|SP|SU)+[0-9]/);
    let year;
    if(pos==-1)
        return false;
    else{
        year = course_name.substring(pos+2, pos+4);
        if(!isNaN(year)){
            if(parseInt(year)>24)
                return true;
        }
    }
    return false;
}
  
