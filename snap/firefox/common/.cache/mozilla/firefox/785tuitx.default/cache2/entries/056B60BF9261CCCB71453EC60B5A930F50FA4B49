function changeHomepage(){
    let pageVal =  {
        "course[default_view]": "modules",
      };
    
      $.ajax({
        url: '/api/v1/courses/' + ENV.current_context.id,
        dataType: 'json',
        type: "PUT",
        data: pageVal,
        success: function(){
            //document.getElementById("change_homepage").textContent = "Homepage Reset";
            let icon = $('i[class="icon-reset"]')
            for(let i=0; i<icon.length; i++)
                icon[i].setAttribute("class", "icon-check");
        },
        error: function(){
            console.log("Error: homepage unable to change")
        }
      });
}

function waitForSimple(){
    if($('.tool_content_wrapper').length>0){
